# 디wan الصوفية Frontend - Environment Variables
# Copy to .env.local for local development

# ═══════════════════════════════════════════════════════════════════════════════
# API Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Production: Your Render backend URL
VITE_API_BASE=https://diwan-sufi-api.onrender.com

# Development: Your local backend URL (set when running locally)
# VITE_API_BASE=https://localhost:7145

# Legacy (for Vercel environment variables)
API_BASE=https://diwan-sufi-api.onrender.com

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend Configuration (optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Node environment (auto-set by Vercel)
NODE_ENV=production

